{
  "name": "functions",
  "scripts": {
    "lint": "eslint src --ext .ts",
    "build": "tsc",
    "serve": "npm run build && GOOGLE_APPLICATION_CREDENTIALS=key.json firebase emulators:start",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run serve",
    "firestore-emulator": "firebase emulators:start --only firestore",
    "test": "FIRESTORE_EMULATOR_HOST=localhost:8999 jest --detectOpenHandles",
    "test:with-emulator": "firebase emulators:exec --only firestore \"npm run test\"",
    "test:watch": "FIRESTORE_EMULATOR_HOST=localhost:8999 jest --watch --detectOpenHandles",
    "test:coverage": "FIRESTORE_EMULATOR_HOST=localhost:8999 jest --coverage --detectOpenHandles",
    "deploy": "firebase deploy --project default",
    "deploy:staging": "firebase deploy --project staging",
    "logs": "firebase functions:log"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@aws-sdk/client-sts": "^3.750.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.9.0",
    "jsonwebtoken": "^8.5.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^2.0.7",
    "@types/body-parser": "^1.19.0",
    "@types/cors": "^2.8.5",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "firebase": "^9.23.0",
    "firebase-functions-test": "^3.4.0",
    "firebase-tools": "^13.29.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "private": true,
  "engines": {
    "node": "22"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
    },
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "lib/",
      "node_modules/"
    ],
    "testEnvironment": "node"
  }
}
